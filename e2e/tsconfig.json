{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "moduleResolution": "bundler",
        "lib": ["ES2022", "DOM", "DOM.Iterable"],
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "types": ["node"],
        "noEmit": true
    },
    "include": ["**/*.ts", "../playwright.config.ts"]
}
